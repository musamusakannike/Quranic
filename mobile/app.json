{
  "expo": {
    "name": "Quranic",
    "slug": "Quranic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quranic",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.codiac.quranic",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.codiac.quranic"
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png",
      "pwa": {
        "name": "Quranic",
        "shortName": "Quranic",
        "themeColor": "#056C5C",
        "backgroundColor": "#ffffff",
        "display": "standalone",
        "orientation": "portrait"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-background-task",
      "expo-localization",
      "expo-notifications",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      "expo-video",
      "expo-font",
      "expo-image",
      "expo-sharing",
      "expo-web-browser",
      "expo-asset",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Quranic to use your location."
        }
      ],
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "PrayerWidget",
              "displayName": "Prayer Times",
              "description": "View next prayer time and countdown.",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "PrayerWidget",
              "label": "Prayer Times",
              "description": "Prayer times and countdown",
              "src": "./widgets/AndroidPrayerWidget.tsx",
              "updatePeriodMillis": 900000,
              "minWidth": "60dp",
              "minHeight": "60dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3e87db0c-ef6e-4b07-93f5-200d8e26e52f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3e87db0c-ef6e-4b07-93f5-200d8e26e52f"
    }
  }
}
